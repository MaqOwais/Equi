# ─── Supabase ──────────────────────────────────────────────────────────────────
# Find in: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Groq AI (zero data retention) ────────────────────────────────────────────
# Get from: console.groq.com → API Keys
# Used for: AI Wellness Report generation (Llama 3.1 70B)
EXPO_PUBLIC_GROQ_API_KEY=gsk_your-groq-key-here

# ─── Sentry (crash reporting) ──────────────────────────────────────────────────
# Get from: sentry.io → Project Settings → Client Keys (DSN)
# Only active in production builds (not in Expo Go)
EXPO_PUBLIC_SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX

# ─── Copy this file to .env.local and fill in real values ─────────────────────
# .env.local is gitignored — never commit real keys
